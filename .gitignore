# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Release signing
/android/key.properties
/keystore/*.jks
/keystore/*.keystore
/keystore/*.p12
/keystore/*.pfx

# (Optional) If you ever store keystores elsewhere
*.jks
*.keystore

# Release outputs (optional)
*.aab
*.apk
